# observability-mcp — environment variables
# Copy this file to .env and fill in your values.
# Only set the variables for backends you want to enable.

# ─── Grafana (self-hosted, v9+) ──────────────────────────────────────────────
# Required to enable Grafana tools (grafana_health, grafana_list_datasources,
# grafana_query_metrics, grafana_list_dashboards, grafana_get_dashboard)
GRAFANA_URL=https://grafana.myco.internal

# Service account token — Viewer role is sufficient (recommended)
GRAFANA_TOKEN=glsa_...

# Set to "false" to skip TLS certificate verification (not recommended for production)
# GRAFANA_VERIFY_SSL=true

# ─── Prometheus ──────────────────────────────────────────────────────────────
# Required to enable Prometheus tools (prometheus_health, prometheus_query,
# prometheus_query_range, prometheus_list_metrics, prometheus_metric_metadata)
PROMETHEUS_URL=https://prometheus.myco.internal

# Optional basic auth (only if your Prometheus is protected)
# PROMETHEUS_USERNAME=
# PROMETHEUS_PASSWORD=

# ─── Kafka UI (provectus/kafka-ui) ───────────────────────────────────────────
# Required to enable Kafka tools (kafka_list_clusters, kafka_list_topics,
# kafka_describe_topic, kafka_list_consumer_groups, kafka_consumer_group_lag,
# kafka_broker_health)
KAFKA_UI_URL=https://kafka-ui.myco.internal

# Optional basic auth (if your Kafka UI is protected with login)
# KAFKA_UI_USERNAME=admin
# KAFKA_UI_PASSWORD=

# ─── Datadog (proxies official Datadog MCP) ──────────────────────────────────
# Both keys are required to enable Datadog tools.
# Create an API key: Datadog → Organization Settings → API Keys
# Create an Application key: Datadog → Organization Settings → Application Keys
# DD_API_KEY=
# DD_APP_KEY=

# Your Datadog site — defaults to datadoghq.com (US1) if not set.
# Sites: datadoghq.com (US1) | us3.datadoghq.com | us5.datadoghq.com
#         datadoghq.eu (EU1) | ap1.datadoghq.com
# DD_SITE=datadoghq.com

# Comma-separated list of Datadog tool groups to expose.
# Defaults to "core,apm,alerting" if not set. Use "all" for all 100+ tools.
# Available: core, apm, alerting, logs, incidents, ddsql, security, synthetics,
#            networks, dbm, software-delivery, llm-obs, cases, feature-flags
# DD_TOOLSETS=core,apm,alerting
